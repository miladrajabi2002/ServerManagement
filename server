        if [ "$have_dns_tool" -eq 0 ]; then
            _ipr_skip "No DNS lookup tool found. Install dnsutils/bind-utils."
        else
            for rbl in "${rbls[@]}"; do
                ans="$(_ipr_rbl_answers "${reversed_ip}.${rbl}")"
                if [ -n "$ans" ]; then
                    if printf '%s\n' "$ans" | grep -qE '^127\.255\.255\.'; then
                        rbl_errors=$((rbl_errors + 1))
                        err_names="$err_names$rbl($ans) "
                    else
                        blacklisted=$((blacklisted + 1))
                        bl_names="$bl_names$rbl($ans) "
                    fi
                fi
            done

            if [ "$blacklisted" -eq 0 ] && [ "$rbl_errors" -eq 0 ]; then
                _ipr_ok "DNSBL Status: ${C_GREEN}Clean (0/${#rbls[@]} lists)${C_NC}" 18

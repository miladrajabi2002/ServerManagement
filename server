        if command -v jq >/dev/null 2>&1; then
            printf '%s' "$json" | jq -r "($path // []) | if type==\"array\" then map(tostring) | join(\",\") else tostring end" 2>/dev/null
        elif command -v python3 >/dev/null 2>&1; then
            PY_JSON="$json" PY_PATH="$path" python3 - <<'PY' 2>/dev/null
import json, os, sys
try:
    obj = json.loads(os.environ.get("PY_JSON", ""))
except Exception:
    sys.exit(0)
path = os.environ.get("PY_PATH", "").strip()
if path.startswith('.'):
    path = path[1:]
cur = obj
if path:
    for part in path.split('.'):
        if isinstance(cur, dict):
            cur = cur.get(part)
        elif isinstance(cur, list) and part.isdigit() and int(part) < len(cur):
            cur = cur[int(part)]
        else:
            cur = []
            break
if isinstance(cur, list):
    print(",".join(str(x) for x in cur))
elif cur is not None:
    print(cur)
PY
        else
            echo ""
        fi
    }

    _ipr_is_ipv4() {
        local ip="$1"
        awk -F. 'NF==4 { for (i=1;i<=4;i++) if ($i !~ /^[0-9]+$/ || $i < 0 || $i > 255) exit 1; exit 0 } { exit 1 }' <<< "$ip"
    }

    _ipr_version() {
        local ip="$1"
        if _ipr_is_ipv4 "$ip"; then
            echo 4
        elif [[ "$ip" == *:* ]]; then
            echo 6
        else
            echo 0
        fi
    }

    local total_checks=0 passed_checks=0 critical_issues=0 warning_issues=0
    local total_weight=0 earned_weight=0 skipped_checks=0

    _ipr_score() {
        local weight="${1:-0}" state="$2"
        [[ "$weight" =~ ^[0-9]+$ ]] || weight=0
        [ "$weight" -gt 0 ] || return 0
        total_checks=$((total_checks + 1))
        total_weight=$((total_weight + weight))
        case "$state" in
            pass)
                passed_checks=$((passed_checks + 1))
                earned_weight=$((earned_weight + weight))
                ;;
            warn)
                warning_issues=$((warning_issues + 1))
                earned_weight=$((earned_weight + weight / 2))
                ;;
            fail)
                critical_issues=$((critical_issues + 1))
                ;;
        esac
    }

    _ipr_ok()   { local msg="$1" weight="${2:-0}"; echo -e "  ${C_GREEN}✓${C_NC} $msg"; _ipr_score "$weight" pass; }
    _ipr_warn() { local msg="$1" weight="${2:-0}"; echo -e "  ${C_YELLOW}⚠${C_NC} $msg"; _ipr_score "$weight" warn; }
    _ipr_bad()  { local msg="$1" weight="${2:-0}"; echo -e "  ${C_RED}✗${C_NC} $msg"; _ipr_score "$weight" fail; }
    _ipr_skip() { local msg="$1"; skipped_checks=$((skipped_checks + 1)); echo -e "  ${C_DIM}• $msg${C_NC}"; }

    _ipr_rbl_answers() {
        local q="$1"
        if command -v dig >/dev/null 2>&1; then
            dig +short A "$q" 2>/dev/null | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' || true
        elif command -v host >/dev/null 2>&1; then
            host "$q" 2>/dev/null | awk '/has address/ {print $NF}' | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' || true
        elif command -v nslookup >/dev/null 2>&1; then
            nslookup "$q" 2>/dev/null | awk '/^Address: / {print $2}' | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' || true
        else
            return 2
        fi
    }

    _ipr_header "IP REPUTATION & SECURITY ANALYSIS"


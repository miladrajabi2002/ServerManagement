check_service_status() {
    local service=$1
    local display_name=$2
    
    if systemctl list-unit-files | grep -q "^${service}.service"; then
        if systemctl is-active --quiet "$service"; then
            echo -e "  ${GREEN}✓${NC} $display_name: ${GREEN}${BOLD}Running${NC}"
            return 0
        else
            echo -e "  ${RED}✗${NC} $display_name: ${RED}${BOLD}Stopped${NC}"
            return 1
        fi
    else
        echo -e "  ${DIM}○${NC} $display_name: ${DIM}Not installed${NC}"
        return 2
    fi
}

service_exists() {
    systemctl list-unit-files --type=service --no-legend 2>/dev/null | awk '{print $1}' | grep -Fxq "$1.service"
}

service_error_summary() {
    local service="$1"
    local logfile="$2"
    local journal_err=""
    local file_err=""

    journal_err=$(journalctl -u "$service" -p err -n 1 --no-pager 2>/dev/null | tail -n 1)
    if [ -n "$journal_err" ] && [[ "$journal_err" != *"-- No entries --"* ]]; then
        echo "$journal_err"
        return
    fi

    if [ -f "$logfile" ]; then
        file_err=$(grep -iE "error|fail|critical|panic|emerg|alert" "$logfile" 2>/dev/null | tail -n 1)
        [ -n "$file_err" ] && echo "$file_err"
    fi
}

find_php_fpm_service() {
    local php_service
    php_service=$(systemctl list-unit-files --type=service --no-legend 2>/dev/null | awk '/^php[0-9]+\.[0-9]+-fpm\.service/ {print $1}' | sed 's/\.service$//' | sort -Vr | head -n1)
    echo "$php_service"
}

analyze_php_workers() {
    local active_workers="$1"
    local max_children="$2"

    if [ -z "$max_children" ] || ! [[ "$max_children" =~ ^[0-9]+$ ]]; then
        print_status "WARN" "Unable to detect pm.max_children from pool config"
        return
    fi

    local usage=$((active_workers * 100 / max_children))
    print_status "INFO" "Worker Capacity: $active_workers / $max_children (${usage}%)"

    if [ "$active_workers" -gt "$max_children" ]; then
        print_status "ERROR" "Worker count exceeds pm.max_children (tuning required)"
    elif [ "$usage" -ge 85 ]; then
        print_status "WARN" "Worker utilization is high (>=85%)"
    else
        print_status "SUCCESS" "Worker utilization is in normal range"
    fi
}


        echo -e "\n${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
        
        echo -ne "${YELLOW}${BOLD}Select option:${NC} "
        read choice
        
        case $choice in
            1) network_optimization_menu ;;
            2) check_ip_reputation ;;
            3) optimize_mirrors ;;
            4) monitoring ;;
            5) run_benchmark ;;

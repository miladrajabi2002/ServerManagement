normalize_log_line() {
    local source="$1"
    local service="$2"
    local raw_line="$3"

    local ts host pid severity message
    ts=$(echo "$raw_line" | awk '{print $1" "$2" "$3}')
    host=$(echo "$raw_line" | awk '{print $4}')
    pid=$(echo "$raw_line" | sed -n 's/.*\[\([0-9]\+\)\].*/\1/p' | head -n1)
    [ -z "$pid" ] && pid="-"

    if echo "$raw_line" | grep -qiE "panic|crit|critical|emerg|alert"; then
        severity="critical"
    elif echo "$raw_line" | grep -qiE "error|fail|denied"; then
        severity="error"
    elif echo "$raw_line" | grep -qiE "warn|warning|deprecated"; then
        severity="warning"
    else
        severity="info"
    fi

    message=$(echo "$raw_line" | sed 's/"/'\''/g')
    printf '{"timestamp":"%s","host":"%s","service":"%s","severity":"%s","message":"%s","source_file":"%s","pid":"%s"}\n' \
        "$ts" "${host:-localhost}" "$service" "$severity" "$message" "$source" "$pid" >> "$LOG_PIPELINE_FILE"
}

build_unified_log_pipeline() {
    print_section "UNIFIED LOG PIPELINE"
    print_breadcrumb "Service & Log Management > Logs > Pipeline"
    print_context_help "Journald and log files are normalized into NDJSON records."

    : > "$LOG_PIPELINE_FILE"

    while IFS= read -r line; do
        normalize_log_line "journald" "system" "$line"
    done < <(journalctl -p err -n 120 --no-pager 2>/dev/null)

    for file in /var/log/syslog /var/log/messages /var/log/auth.log "$NGINX_ERROR_LOG" /var/log/mysql/error.log /var/log/redis/redis-server.log; do
        [ -f "$file" ] || continue
        while IFS= read -r line; do
            normalize_log_line "$file" "$(basename "$file")" "$line"
        done < <(tail -n 60 "$file" 2>/dev/null)
    done

    local count
    count=$(wc -l < "$LOG_PIPELINE_FILE" 2>/dev/null)
    print_status "SUCCESS" "Pipeline generated with ${count:-0} normalized records"
    print_status "INFO" "Output file: $LOG_PIPELINE_FILE"
}

print_error_digest_row() {
    local title="$1"
    local pattern="$2"
    local count first_seen last_seen
    count=$(grep -iE "$pattern" "$LOG_PIPELINE_FILE" 2>/dev/null | wc -l)
    first_seen=$(grep -iE "$pattern" "$LOG_PIPELINE_FILE" 2>/dev/null | head -n1 | sed -n 's/.*"timestamp":"\([^"]*\)".*/\1/p')
    last_seen=$(grep -iE "$pattern" "$LOG_PIPELINE_FILE" 2>/dev/null | tail -n1 | sed -n 's/.*"timestamp":"\([^"]*\)".*/\1/p')

    [ -z "$first_seen" ] && first_seen="-"
    [ -z "$last_seen" ] && last_seen="-"
    printf "  %-28s | %-6s | %-20s | %-20s\n" "$title" "$count" "$first_seen" "$last_seen"
}


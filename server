    echo -e "${C_CYAN}${C_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_NC}"
    echo -e "${C_CYAN}${C_BOLD}  SECURITY ANALYSIS IN PROGRESS${C_NC}"

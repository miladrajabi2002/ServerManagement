    if [ "$ip_ver" = "4" ]; then
        local reversed_ip blacklisted=0 rbl_errors=0 bl_names="" err_names="" rbl ans
        reversed_ip=$(awk -F. '{print $4"."$3"."$2"."$1}' <<< "$PUBLIC_IP")
        local rbls=("zen.spamhaus.org" "bl.spamcop.net" "dnsbl.sorbs.net" "b.barracudacentral.org")
        local have_dns_tool=1
        if ! command -v dig >/dev/null 2>&1 && ! command -v host >/dev/null 2>&1 && ! command -v nslookup >/dev/null 2>&1; then

    if [ "$filled" -gt 0 ]; then printf '█%.0s' $(seq 1 "$filled"); fi
    echo -ne "$C_GRAY"
    if [ "$empty" -gt 0 ]; then printf '░%.0s' $(seq 1 "$empty"); fi
    echo -e "${C_NC} ${C_BOLD}${score}%${C_NC}\n"

    echo -e "${C_BLUE}┌─────────────────────────────────────────────────────────────┐${C_NC}"
    printf "${C_BLUE}│${C_NC} ${C_BOLD}%-20s${C_NC} ${C_BLUE}│${C_NC} ${color}${C_BOLD}%-34s${C_NC} ${C_BLUE}│${C_NC}\n" "Status" "$emoji $status_text"
    printf "${C_BLUE}│${C_NC} ${C_BOLD}%-20s${C_NC} ${C_BLUE}│${C_NC} ${C_GREEN}%-34s${C_NC} ${C_BLUE}│${C_NC}\n" "Checks Passed" "$passed_checks / $total_checks"
    printf "${C_BLUE}│${C_NC} ${C_BOLD}%-20s${C_NC} ${C_BLUE}│${C_NC} ${C_YELLOW}%-34s${C_NC} ${C_BLUE}│${C_NC}\n" "Warnings" "$warning_issues"
    printf "${C_BLUE}│${C_NC} ${C_BOLD}%-20s${C_NC} ${C_BLUE}│${C_NC} ${C_RED}%-34s${C_NC} ${C_BLUE}│${C_NC}\n" "Critical Issues" "$critical_issues"
    printf "${C_BLUE}│${C_NC} ${C_BOLD}%-20s${C_NC} ${C_BLUE}│${C_NC} ${C_DIM}%-34s${C_NC} ${C_BLUE}│${C_NC}\n" "Skipped" "$skipped_checks"
    echo -e "${C_BLUE}└─────────────────────────────────────────────────────────────┘${C_NC}\n"

    if [ "$score" -lt 85 ] || [ "$critical_issues" -gt 0 ]; then
        echo -e "${C_YELLOW}${C_BOLD}⚠ RECOMMENDATIONS:${C_NC}\n"
        [ "$critical_issues" -gt 0 ] && echo -e "  ${C_RED}•${C_NC} If this is a VPS/server, patch exposed services and close unused ports before changing IP."
        echo -e "  ${C_CYAN}•${C_NC} If DNSBL-listed, check your mail server, rDNS/PTR, SPF/DKIM/DMARC, and abuse logs."
        echo -e "  ${C_CYAN}•${C_NC} For more accurate paid/free-tier API checks, export keys before running:"
        echo -e "    ${C_DIM}export ABUSEIPDB_KEY='...' IPQS_KEY='...' IPHUB_KEY='...' GETIPINTEL_CONTACT='you@example.com'${C_NC}"
        echo -e "  ${C_CYAN}•${C_NC} Manual pages:"
        echo -e "    ${C_BLUE}https://scamalytics.com/ip/$PUBLIC_IP${C_NC}"
        echo -e "    ${C_BLUE}https://www.abuseipdb.com/check/$PUBLIC_IP${C_NC}"
    fi

    _ipr_pause
}


show_duplicate_process_detection() {
    print_section "DUPLICATE PROCESS DETECTION"
    print_breadcrumb "Service & Log Management > Processes > Duplicates"
    print_context_help "Detect duplicate workloads based on binary/args/parent tree."

    local duplicates
    duplicates=$(
        ps -eo ppid=,pid=,comm=,args= 2>/dev/null \
        | awk '
            {
                cmd_start = index($0,$4);
                cmd = (cmd_start>0 ? substr($0,cmd_start) : "-");
                key=$3"|"cmd;
                c[key]++;
                if (!sample_ppid[key]) sample_ppid[key]=$1;
                if (!sample_pid[key]) sample_pid[key]=$2;
                if (!sample_comm[key]) sample_comm[key]=$3;
                if (!sample_cmd[key]) sample_cmd[key]=cmd;
            }
            END {for (k in c) if (c[k] > 1) printf "%-8s %-8s %-20s %-36s %5d\n", sample_ppid[k], sample_pid[k], sample_comm[k], sample_cmd[k], c[k]; }' \
        | head -n 12
    )
    if [ -n "$duplicates" ]; then
        print_status "WARN" "Potential duplicate workloads:"
        echo "  PPID     PID      PROCESS              COMMAND                              COUNT"
        echo "  -------------------------------------------------------------------------------"
        echo "$duplicates" | sed 's/^/  /'
    else
        print_status "SUCCESS" "No significant duplicate process pattern found"
    fi
}

show_process_abnormal_patterns() {
    print_section "LEAK / ABNORMAL PATTERN DETECTION"
    print_breadcrumb "Service & Log Management > Processes > Abnormal Patterns"
    print_context_help "High-risk patterns: CPU pegging, RAM pressure, zombie accumulation."

    local pegged highmem zombies
    pegged=$(
        ps -eo pid=,comm=,%cpu=,args= --sort=-%cpu 2>/dev/null \
        | awk -v threshold="$CPU_PEG_THRESHOLD" '$3 > threshold {printf "%-8s %-20s CPU=%-6s %s\n", $1, $2, $3"%", substr($0, index($0,$4))}' \
        | head -n 5
    )

    highmem=$(
        ps -eo pid=,comm=,%mem=,rss=,args= --sort=-%mem 2>/dev/null \
        | awk -v threshold="$MEM_HIGH_THRESHOLD" '$3 > threshold {printf "%-8s %-20s MEM=%-6s RSS=%sKB  %s\n", $1, $2, $3"%", $4, substr($0, index($0,$5))}' \
        | head -n 5
    )

    zombies=$(
        ps -eo stat= 2>/dev/null \
        | awk '$1 ~ /Z/ {count++} END {print count+0}'
    )

    if [ -n "$pegged" ]; then
        print_status "WARN" "CPU pegging processes (>${CPU_PEG_THRESHOLD}%):"
        echo "$pegged" | sed 's/^/  - /'
    else
        print_status "SUCCESS" "No CPU pegging process detected"
    fi

    if [ -n "$highmem" ]; then
        print_status "WARN" "High memory processes (>${MEM_HIGH_THRESHOLD}%):"
        echo "$highmem" | sed 's/^/  - /'
    else
        print_status "SUCCESS" "No single process with very high memory usage"
    fi

    if [ "$zombies" -gt 0 ]; then
        print_status "WARN" "Zombie processes detected: $zombies"
        ps -eo pid=,ppid=,stat=,comm=,args= 2>/dev/null \
            | awk '$3 ~ /Z/ {printf "  - PID=%s PPID=%s STAT=%s CMD=%s\n", $1, $2, $3, substr($0, index($0,$5))}' \
            | head -n 10
    else
        print_status "SUCCESS" "No zombie process accumulation"
    fi
}


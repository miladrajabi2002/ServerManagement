show_log_anomaly_detection() {
    print_section "LOG ANOMALY DETECTION"
    print_breadcrumb "Service & Log Management > Logs > Anomaly Detection"
    print_context_help "Compares recent 15-minute errors vs previous 15 minutes to detect spikes."

    local recent previous new_patterns
    recent=$(journalctl --since "15 min ago" -p err --no-pager 2>/dev/null | wc -l)
    previous=$(journalctl --since "30 min ago" --until "15 min ago" -p err --no-pager 2>/dev/null | wc -l)

    print_status "INFO" "Recent errors (15m): $recent"
    print_status "INFO" "Previous window errors (15m): $previous"

    if [ "$previous" -eq 0 ] && [ "$recent" -gt 0 ]; then
        print_status "WARN" "New error burst detected (no errors in previous window)"
    elif [ "$previous" -gt 0 ] && [ "$recent" -ge $((previous * 2)) ]; then
        print_status "WARN" "Error rate spike detected (>=2x)"
    else
        print_status "SUCCESS" "No significant anomaly detected"
    fi

    new_patterns=$(journalctl --since "15 min ago" -p err --no-pager 2>/dev/null | awk '{$1=$2=$3=""; print $0}' | sort -u | head -n 5)
    if [ -n "$new_patterns" ]; then
        echo -e "${CYAN}${BOLD}  Recent unique patterns:${NC}"
        echo "$new_patterns" | sed 's/^/    - /'
    fi
}

